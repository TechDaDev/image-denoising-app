# Ignore everything by default
*

# Allow the .gitignore file itself
!.gitignore

# Allow the app files
!app.py
!README.md
!requirements.txt

# Allow models directory and its contents
!models/
!models/*.h5
!models/*.hdf5
!models/*.pth

# Common ignores
__pycache__/
*.py[cod]
*$py.class
.idea/
.vscode/
venv/
env/

# Ignore OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db