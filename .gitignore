# Ignore everything by default
*

# Allow the .gitignore file itself
!.gitignore

# Allow the app files (moved to root)
!app.py
!README.md
!requirements.txt
!models/

# Common ignores
__pycache__/
*.py[cod]
*$py.class
.idea/
.vscode/
venv/
env/

# Ignore model files
*.h5
*.hdf5
*.pth
*.pkl

# Ignore OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.pkl
.DS_Store
Thumbs.db
